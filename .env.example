# Copy this file to ".env" in the project root and fill in the values.
# Never commit .env (it is gitignored).

# --- Required for Mortgage Automator (placement + enrich steps) ---
# MA_ACCOUNT_ID is accepted as an alias for MA_LENDER_ID (mysite already uses MA_ACCOUNT_ID).
# MA_BASE_URL  is accepted as an alias for MA_API_BASE_V1 (e.g. https://us-east.mortgageautomator.com/api).
MA_LENDER_ID=
MA_API_KEY=
# MA_API_BASE_V1=

# --- Required for SharePoint workbooks (Microsoft Graph Excel API) ---
# Same client-credentials app you already use for sharepoint_draw_upload / graph_inbox.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Optional overrides (defaults shown match Loan Mountain Capital's tenant).
# SP_HOSTNAME=loanmountaincapital.sharepoint.com
# SP_SITE_RELATIVE_PATH=sites/LoanMountainCapital-General
# EXCEL_PATCHER_SP_PATH=General/Project Raptor 3/Underwritting/Placement Fee Patching.xlsx
# EXCEL_TRACKER_SP_PATH=General/Project Raptor 3/Sales/Master Tracker Points Average.xlsx

# --- Optional: load secrets from another file (e.g. PA: ~/.secrets/lmc.env) ---
# Set DOTENV_PATH in the environment before running Python so config picks it up first.
# DOTENV_PATH=

# --- Optional: API smoke test (py -3 orchestrator.py --verify --verify-api) ---
# VERIFY_LOAN_ID=12345

# --- Optional: Anthropic (not used by current code until you wire summaries) ---
# ANTHROPIC_API_KEY=

# --- Enricher: how many Master rows to hit (Creation Date filter, UTC) ---
# days = now minus ENRICHER_LOOKBACK_DAYS (default 14; use 1-2 for quick tests).
# since_last_run = use logs/last_enricher_run.iso minus overlap; first run falls back to days.
# ENRICHER_LOOKBACK_MODE=days
# ENRICHER_LOOKBACK_DAYS=14
# ENRICHER_LOOKBACK_OVERLAP_HOURS=24
# ENRICHER_LAST_RUN_FILE=
# ENRICHER_TABLE_NAME=tbl_avgpoints
# PATCHER_TABLE_NAME=tbl_of

# --- Webhook (Flask on PythonAnywhere; see flask_webhook.py + README) ---
# Shared secret for POST /webhook/loan-automator (header X-Webhook-Secret, X-Loan-Automator-Secret,
# Bearer token, ?token=, or JSON "secret"). Use the same value in Zapier.
# LOAN_AUTOMATOR_WEBHOOK_SECRET=
# SQLite queue file (default: logs/loan_automator_queue.sqlite under this repo)
# QUEUE_DB_PATH=
# Local only: allow webhook without secret (NEVER in production)
# LOAN_AUTOMATOR_WEBHOOK_ALLOW_INSECURE=1
